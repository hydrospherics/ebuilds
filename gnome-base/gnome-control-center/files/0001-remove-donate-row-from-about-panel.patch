+++ b/panels/system/about/cc-about-page.blp
@@ -24,25 +24,6 @@ template $CcAboutPage: Adw.NavigationPage {
         }
       }
 
-      Adw.PreferencesGroup {
-        Adw.ActionRow {
-          title: _("Support GNOME");
